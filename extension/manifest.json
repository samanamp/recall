{
  "manifest_version": 3,
  "name": "recall — flashcard from selection",
  "version": "0.1.0",
  "description": "Highlight text on any page and turn it into a spaced-repetition flashcard in your recall deck.",
  "permissions": ["contextMenus", "storage", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "options_page": "options.html",
  "action": {
    "default_title": "recall — settings",
    "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png" }
  },
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
